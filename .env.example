# ========================================
# Superset Configuration
# ========================================

# Secret key protects the local superset database
# Generate using: openssl rand -base64 42
SECRET_KEY=

# Admin user credentials
ADMIN_USERNAME=admin
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=User
ADMIN_EMAIL=admin@superset.com
ADMIN_PASSWORD=admin

# ========================================
# Redis Configuration (Production)
# ========================================

# Redis connection settings
# Leave REDIS_HOST empty or unset for development mode (uses SimpleCache)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ========================================
# Gunicorn Configuration (Production)
# ========================================

# Number of worker processes (default: CPU count * 2 + 1)
GUNICORN_WORKERS=4

# Number of threads per worker
GUNICORN_THREADS=4

# Request timeout in seconds
GUNICORN_TIMEOUT=300

# Log level (debug, info, warning, error, critical)
GUNICORN_LOG_LEVEL=info

# ========================================
# Nginx Configuration
# ========================================

# Port for Nginx to listen on
NGINX_PORT=80

# ========================================
# Application Configuration
# ========================================

# Log level for Superset
LOG_LEVEL=INFO

# ========================================
# MDH Configuration (Multi-Project)
# ========================================

# Option 1: JSON array of MDH projects (recommended for multiple projects)
# Each project needs: alias, account_secret_b64, account_name, project_id, schema_name, s3_output
# MDH_PROJECTS=[{"alias": "myproject", "account_secret_b64": "<base64_encoded_key>", "account_name": "MyDataHelps.XXXX.user", "project_id": "uuid-here", "schema_name": "my_schema", "s3_output": "s3://my-bucket/path/"}]

# Option 2: YAML file (alternative - create mdh_projects.yaml, see mdh_projects.yaml.example)
# MDH_CONFIG_FILE=mdh_projects.yaml

# Option 3: Single project (legacy)
# MDH_SECRET=<base64_encoded_key>
# MDH_ACC_NAME=MyDataHelps.XXXX.user
# MDH_PROJECT_ID=uuid-here
# MDH_SCHEMA=my_schema
# MDH_S3=s3://my-bucket/path/

# ========================================
# Table Access Control
# ========================================

# Block entire tables from being queried in SQL Lab (comma-separated)
# Example: BLOCKED_TABLES=allparticipants,sensitive_data,internal_logs
BLOCKED_TABLES=

# Allow specific columns from blocked tables (comma-separated, table.column format)
# Users can only SELECT these columns from the blocked tables above
# Example: ALLOWED_COLUMNS=allparticipants.customfields,allparticipants.participantid
ALLOWED_COLUMNS=

# Block specific field names from appearing anywhere in queries (comma-separated)
# Useful for blocking sensitive fields inside JSON columns like customfields
# Example: BLOCKED_FIELDS=ssn,social_security,date_of_birth,dob,phone_number,email,address
BLOCKED_FIELDS=